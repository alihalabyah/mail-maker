# Database
DATABASE_URL="postgresql://mailmaker:mailmaker@localhost:5433/mailmaker"

# JWT
JWT_SECRET="change-me-to-a-long-random-string-at-least-32-chars"
JWT_EXPIRY="7d"

# S3 / Object Storage (AWS S3 or OCI-compatible)
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="your-access-key-id"
AWS_SECRET_ACCESS_KEY="your-secret-access-key"
S3_BUCKET="mail-maker-assets"
# Leave blank for real AWS S3.
# For OCI: https://<namespace>.compat.objectstorage.<region>.oraclecloud.com
# For LocalStack: http://localhost:4566
# For MinIO: http://localhost:9000
STORAGE_ENDPOINT=""

# SMTP — used by the /v1/send-test endpoint
# Mailpit (local): host=localhost port=1025
# For production point this at your real SMTP relay
SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_FROM="mailmaker@mail-maker.local"

# App
PORT=3001
NODE_ENV="development"

# CORS (comma-separated list of allowed origins)
CORS_ORIGINS="http://localhost:3000"

# Admin seed (used by: npm run db:seed)
# Email is hardcoded to ali@qashio.com in seed.ts; set ADMIN_PASSWORD to override the default
ADMIN_PASSWORD="changeme123"
