generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum ApiKeyScope {
  READ_ONLY
  RENDER
  ADMIN
}

model User {
  id                String            @id @default(cuid())
  email             String            @unique
  passwordHash      String
  role              Role              @default(USER)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  templates         Template[]
  templateVersions TemplateVersion[]
  apiKeys           ApiKey[]
  components        Component[]
}

model Domain {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  templates   Template[]
  components  Component[]
}

model Template {
  id               String            @id @default(cuid())
  slug             String            @unique   // kept for backwards compat, derived as baseSlug[-locale]
  baseSlug         String
  locale           String            @default("en")
  status           String            @default("draft")  // "draft" | "published"
  name             String
  description      String?
  subject          String
  designJson       Json
  htmlTemplate     String            @db.Text
  variables        Json              @default("[]")
  currentVersionId String?
  currentVersion   TemplateVersion?  @relation("CurrentVersion", fields: [currentVersionId], references: [id])
  versions         TemplateVersion[] @relation("AllVersions")
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  createdById      String
  createdBy        User              @relation(fields: [createdById], references: [id])
  domainId         String?
  domain           Domain?           @relation(fields: [domainId], references: [id])

  @@unique([baseSlug, locale, domainId])
}

model TemplateVersion {
  id            String   @id @default(cuid())
  templateId    String
  template      Template @relation("AllVersions", fields: [templateId], references: [id], onDelete: Cascade)
  version       Int
  htmlTemplate  String   @db.Text
  designJson    Json
  subject       String
  variables     Json
  publishedAt   DateTime @default(now())
  publishedById String
  publishedBy   User     @relation(fields: [publishedById], references: [id])

  // Back-reference for currentVersion on Template (one-to-one optional)
  currentFor    Template[] @relation("CurrentVersion")

  @@unique([templateId, version])
}

model Component {
  id           String   @id @default(cuid())
  slug         String
  name         String
  description  String?
  designJson   Json
  htmlTemplate String   @db.Text
  variables    Json     @default("[]")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  createdById  String
  createdBy    User     @relation(fields: [createdById], references: [id])
  domainId     String?
  domain       Domain?  @relation(fields: [domainId], references: [id])

  @@unique([slug, domainId])
}

model ApiKey {
  id         String        @id @default(cuid())
  name       String
  keyHash    String        @unique
  prefix     String
  scopes     ApiKeyScope[]
  userId     String
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastUsedAt DateTime?
  expiresAt  DateTime?
  createdAt  DateTime      @default(now())
}
